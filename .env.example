# =============================================================================
# LiteLLM SAP BTP Gateway - Environment Variables
# =============================================================================
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# LiteLLM Proxy
# -----------------------------------------------------------------------------
LITELLM_MASTER_KEY=sk-change-me-in-production
LITELLM_SALT_KEY=change-me-random-32-byte-hex-string
LITELLM_LOG=INFO
PORT=8080

# -----------------------------------------------------------------------------
# SAP AI Core Credentials (from service key)
# -----------------------------------------------------------------------------
AICORE_BASE_URL=https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com
AICORE_AUTH_URL=https://your-subaccount.authentication.us10.hana.ondemand.com/oauth/token
AICORE_CLIENT_ID=sb-your-client-id!b388341|aicore!b164
AICORE_CLIENT_SECRET=your-client-secret-here
AICORE_RESOURCE_GROUP=default

# -----------------------------------------------------------------------------
# OAuth2 Token (auto-generated or manual)
# Run: python scripts/aicore_token_helper.py
# -----------------------------------------------------------------------------
AICORE_OAUTH_TOKEN=

# -----------------------------------------------------------------------------
# Model API Base URLs
# =============================================================================
# IMPORTANT: SAP AI Core uses DIFFERENT endpoint patterns per provider!
#
# OpenAI models (GPT):    {base}/v2/inference/deployments/{id}/v1
#   → LiteLLM appends /chat/completions
#
# Anthropic models:       {base}/v2/inference/deployments/{id}
#   → LiteLLM calls /invoke with anthropic_version
#
# Gemini models:          {base}/v2/inference/deployments/{id}
#   → LiteLLM calls /models/{model}:generateContent
#
# Sonar (Perplexity):     {base}/v2/inference/deployments/{id}
#   → LiteLLM appends /chat/completions
# =============================================================================

# OpenAI — note the /v1 suffix!
AICORE_GPT41_API_BASE=https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com/v2/inference/deployments/def4a837c37158f9/v1
AICORE_GPT5_API_BASE=https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com/v2/inference/deployments/dbbd709716d5e3e2/v1

# Anthropic — NO /v1 suffix, LiteLLM calls /invoke
AICORE_CLAUDE_45_SONNET_API_BASE=https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com/v2/inference/deployments/d955f96663d5e62a
AICORE_CLAUDE_45_HAIKU_API_BASE=https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com/v2/inference/deployments/d826e8baca49c5f9

# Gemini — NO suffix, LiteLLM calls /models/{model}:generateContent
AICORE_GEMINI_25_PRO_API_BASE=https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com/v2/inference/deployments/d1a4ec86b5abc63f

# Sonar — NO /v1 suffix, uses /chat/completions directly
AICORE_SONAR_API_BASE=https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com/v2/inference/deployments/d50ba3b92a3cd426

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://litellm:password@localhost:5432/litellm
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
