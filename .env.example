# =============================================================================
# LiteLLM SAP BTP Gateway - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# LiteLLM Proxy Settings
# -----------------------------------------------------------------------------

# Master key for the LiteLLM proxy admin API (must start with sk-)
LITELLM_MASTER_KEY=sk-change-me-in-production

# Salt key for hashing virtual keys (generate with: openssl rand -hex 32)
LITELLM_SALT_KEY=change-me-random-32-byte-hex-string

# Log level: DEBUG, INFO, WARNING, ERROR
LITELLM_LOG=INFO

# Optional: LiteLLM Enterprise license key
# LITELLM_LICENSE=eyJ...

# -----------------------------------------------------------------------------
# SAP AI Core Service Credentials
# (from your AI Core service instance key in SAP BTP)
# -----------------------------------------------------------------------------

# AI Core API base URL (from serviceurls.AI_API_URL in service key)
AICORE_BASE_URL=https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com

# OAuth2 token URL (from 'url' field in service key + /oauth/token)
AICORE_AUTH_URL=https://your-subaccount.authentication.us10.hana.ondemand.com/oauth/token

# OAuth2 client credentials (from service key)
AICORE_CLIENT_ID=sb-your-client-id!t12345|aicore!b1234
AICORE_CLIENT_SECRET=your-client-secret-here

# AI Core Resource Group (default: default)
AICORE_RESOURCE_GROUP=default

# -----------------------------------------------------------------------------
# SAP AI Core Model Deployment IDs
# Replace with your actual deployment IDs from AI Launchpad or API
# Use: cf env <app> or `cf curl /v2/service_instances` to find these
# -----------------------------------------------------------------------------

# GPT-4o via SAP AI Core
AICORE_GPT4O_DEPLOYMENT_ID=d1234567890abcdef

# GPT-4o Mini via SAP AI Core
AICORE_GPT4O_MINI_DEPLOYMENT_ID=d234567890abcdef1

# Claude 3.5 Sonnet via SAP AI Core
AICORE_CLAUDE_35_SONNET_DEPLOYMENT_ID=d34567890abcdef12

# Claude 3 Haiku via SAP AI Core
AICORE_CLAUDE_3_HAIKU_DEPLOYMENT_ID=d4567890abcdef123

# Gemini 1.5 Pro via SAP AI Core
AICORE_GEMINI_15_PRO_DEPLOYMENT_ID=d567890abcdef1234

# Mistral Large via SAP AI Core
AICORE_MISTRAL_LARGE_DEPLOYMENT_ID=d67890abcdef12345

# Llama 3.1 70B via SAP AI Core
AICORE_LLAMA_31_70B_DEPLOYMENT_ID=d7890abcdef123456

# Text Embedding ADA 002 via SAP AI Core
AICORE_TEXT_EMBEDDING_DEPLOYMENT_ID=d890abcdef1234567

# -----------------------------------------------------------------------------
# Database (optional - enables virtual keys, spend tracking, teams)
# If not set, LiteLLM runs in stateless mode (config-only)
# -----------------------------------------------------------------------------

# DATABASE_URL=postgresql://litellm:your-db-password@localhost:5432/litellm

# -----------------------------------------------------------------------------
# Port Configuration
# -----------------------------------------------------------------------------
PORT=8080

# -----------------------------------------------------------------------------
# Optional: Observability & Callbacks
# -----------------------------------------------------------------------------

# Langfuse (LLM observability)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# Slack alerts for hanging requests
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
